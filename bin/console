#!/usr/bin/env php
<?php

require __DIR__ . '/../autoload.php';

use Symfony\Component\Console\Application as ConsoleApplication;
use WebApp\Application;
use WebApp\Console\Commands\RoutesListCommand;

$app = new Application(dirname(__DIR__));

// Load routes the same way as the HTTP front controller.
$router = $app->router;
require __DIR__ . '/../routes/api.php';

$console = new ConsoleApplication('WebApp Console');
$console->addCommand(new RoutesListCommand($app->router->getRouteCollection()));
$console->run();

