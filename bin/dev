#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

BACKEND_HOST="${BACKEND_HOST:-localhost}"
BACKEND_PORT="${BACKEND_PORT:-8001}"
FRONTEND_PORT="${FRONTEND_PORT:-5174}"

BACKEND_PID=""
FRONTEND_PID=""

cleanup() {
  if [[ -n "${FRONTEND_PID}" ]] && kill -0 "${FRONTEND_PID}" 2>/dev/null; then
    kill "${FRONTEND_PID}" 2>/dev/null || true
  fi
  if [[ -n "${BACKEND_PID}" ]] && kill -0 "${BACKEND_PID}" 2>/dev/null; then
    kill "${BACKEND_PID}" 2>/dev/null || true
  fi
}

trap cleanup EXIT INT TERM

echo "Starting backend at http://${BACKEND_HOST}:${BACKEND_PORT} ..."
(cd "${ROOT_DIR}" && php -S "${BACKEND_HOST}:${BACKEND_PORT}" index.php) &
BACKEND_PID="$!"

echo "Starting frontend at http://localhost:${FRONTEND_PORT} ..."
(cd "${ROOT_DIR}/front-end" && npm run dev -- --port "${FRONTEND_PORT}") &
FRONTEND_PID="$!"

wait "${BACKEND_PID}" "${FRONTEND_PID}"

