{
  "name": "webapp/cape-dev-php-framework",
  "type": "library",
  "require": {
    "php": ">=8.1",
    "monolog/monolog": "^3.10",
    "php-di/php-di": "^7.1",
    "symfony/console": "^8.0",
    "symfony/http-foundation": "^8.0",
    "symfony/routing": "^8.0",
    "symfony/validator": "^8.0",
    "vlucas/phpdotenv": "^5.6"
  },
  "autoload": {
    "psr-4": {
      "WebApp\\": "src/",
      "App\\": "app/"
    },
    "files": [
      "src/Support/helpers.php"
    ]
  },
  "config": {
    "sort-packages": true
  },
  "require-dev": {
    "phpunit/phpunit": "^13.0"
  }
}
